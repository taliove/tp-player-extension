{
    "manifest_version": 3,
    "name": "Teleport RDP Web Player",
    "version": "1.0.0",
    "description": "在浏览器中播放 Teleport RDP 录屏，替代 tp-player 桌面应用",
    "content_scripts": [
        {
            "matches": ["*://*/audit/record*"],
            "js": ["content-list.js"],
            "run_at": "document_idle"
        },
        {
            "matches": ["*://*/audit/replay/*"],
            "js": ["content-player.js"],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [{
        "resources": ["css/*", "js/*", "lib/*"],
        "matches": ["<all_urls>"]
    }],
    "icons": {
        "128": "icons/icon128.png"
    }
}
